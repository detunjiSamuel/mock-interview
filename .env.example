# ============================================================
# Mock Interview Platform — environment variables
# Copy this file to .env and fill in the required values.
# ============================================================

# ─── Required — services will NOT start without these ────────────────────────

# Signs JWTs issued by main_api.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Shared secret used in the X-Internal-Secret header for service-to-service
# calls between the worker services and main_api.
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=

# OpenAI API key — used by transcript_service (Whisper) and
# feedback_service (GPT-4o).
OPENAI_API_KEY=

# ─── Optional — sensible defaults are provided ───────────────────────────────

# MongoDB credentials.  Defaults match the official mongo image defaults.
MONGO_USER=root
MONGO_PASSWORD=example

# RabbitMQ credentials.  Defaults match the rabbitmq image defaults.
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
