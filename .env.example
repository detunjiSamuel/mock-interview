# MongoDB
MONGO_USER=root
MONGO_PASSWORD=example
MONGO_URI=mongodb://root:example@localhost:27017/interview?authSource=admin

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URI=amqp://guest:guest@localhost:5672

# Main API
JWT_SECRET=your_jwt_secret_here
PORT=8080
NODE_ENV=development
# FILE_STORAGE_PATH is hardcoded in docker-compose (/app/storage); set this for local non-Docker dev
FILE_STORAGE_PATH=./storage
INTERNAL_API_SECRET=your_internal_secret_here

# Transcript Service
MAIN_API_URL=http://localhost:8080
MAIN_API_APP_ID=transcript_service
# STORAGE_PATH is used by the transcript service to locate uploaded audio files
STORAGE_PATH=/app/storage

# Feedback Service
OPENAI_API_KEY=sk-...
TRANSCRIPT_APP_ID=transcript_service

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
